TIKTOK_API_URL=
INSTAGRAM_API_URL=
FACEBOOK_API_URL=
TWITTER_API_URL=
YOUTUBE_API_URL=
CAPCUT_API_URL=

# ============== RATE LIMIT ==============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
